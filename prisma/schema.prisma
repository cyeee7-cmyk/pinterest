generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  password          String
  name              String?
  pinterestConnected Boolean   @default(false)
  pinterestToken    String?
  pinterestRefreshToken String?
  pinterestUserId   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  pins              Pin[]
}

model Pin {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  description String?
  imageUrl  String
  pinUrl    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
